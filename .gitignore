# Python
.venv/
__pycache__/
*.pyc

# Local Kafka broker runtime (135MB+ distribution + generated log segments —
# not source code; see README for how to download and run it locally)
kafka.tgz
kafka_2.13-4.2.1/
kafka_broker.log

# Local portable JDK 17 + winutils.exe/hadoop.dll for PySpark on Windows —
# see README "Lakehouse setup" for the download commands
jdk17/
hadoop_home/

# Delta Lake tables (generated data, not source)
lakehouse/bronze/*/
lakehouse/silver/*/
lakehouse/gold/*/
lakehouse/_spark_warehouse/
metastore_db/
spark-warehouse/

# ChromaDB persistent vector store (generated data, not source)
rag/vector_db/chroma_persistent/

# OpenLineage event files (one JSON per event, regenerated by each run —
# logs/*.log carries the human-readable [LINEAGE] trail as committed evidence)
lineage/lineage_events/

# Generated data / runtime artifacts (kept as *evidence* selectively via logs/,
# not wholesale — quarantine_zone and the bronze manifest are regenerated by
# running the pipeline)
quarantine_zone/*.json
data/bronze_manifest/*.jsonl

# Airflow runtime artifacts (generated when AIRFLOW_HOME=./airflow in Colab —
# not source; only airflow/dags/ is)
airflow/airflow.cfg
airflow/airflow.db
airflow/webserver_config.py
airflow/logs/
airflow/*.pid

# Secrets
.env
*.env.local
